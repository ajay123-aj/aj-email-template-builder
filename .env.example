# Optional: for "Ask AI" template generation. Copy to .env and set your key.
# VITE_OPENAI_API_KEY=sk-...
# VITE_OPENAI_BASE_URL=https://api.openai.com/v1
# VITE_OPENAI_MODEL=gpt-4o

# Ask AI feature: set to true, 1, or on to show the "Ask AI" button (default: off in dev, on in prod)
# VITE_ASK_AI_ENABLED=false

# App version (optional, for production builds)
# VITE_APP_VERSION=1.0.0

# Production: copy .env.production.example to .env.production before `npm run build`