# Production environment variables
# Copy to .env.production and set values before building

# App version (shown in UI if needed)
VITE_APP_VERSION=1.0.0

# Ask AI: set to true/1/on to show (default: on in production)
VITE_ASK_AI_ENABLED=on

# OpenAI API (required for Ask AI)
VITE_OPENAI_API_KEY=your-api-key
VITE_OPENAI_BASE_URL=https://api.openai.com/v1
VITE_OPENAI_MODEL=gpt-4o
